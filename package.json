{
  "name": "mcp-alexa-server",
  "version": "1.0.0",
  "description": "MCP server for controlling Amazon Alexa devices - send announcements, manage reminders, lists, timers, and trigger routines",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-alexa-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "alexa",
    "model-context-protocol",
    "amazon-alexa",
    "smart-home"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.25.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@vitest/coverage-v8": "^3.1.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^3.1.1"
  }
}
